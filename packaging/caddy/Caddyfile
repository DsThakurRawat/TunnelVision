{
    # Global options
    order tunnelvision before reverse_proxy
}

example.com {
    # Basic tunnelvision integration
    route /tunnelvision/* {
        tunnelvision {
            prefix /tunnelvision
            mode legacy
            ping_interval 30s
            idle_timeout 60s
            # mask_frame
            restrict_to google.com:443 127.0.0.1:22
            # restrict_config /etc/tunnelvision/rules.yaml
        }
    }

    # Serve other content
    handle {
        root * /var/www/html
        file_server
    }
}
